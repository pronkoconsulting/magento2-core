<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <virtualType name="Pronko\Core\Logger\Handler" type="Magento\Framework\Logger\Handler\Base">
        <arguments>
            <argument name="fileName" xsi:type="string">/var/log/pronko.log</argument>
        </arguments>
    </virtualType>
    <virtualType name="Pronko\Core\Logger" type="Magento\Framework\Logger\Monolog">
        <arguments>
            <argument name="name" xsi:type="string">Pronko</argument>
            <argument name="handlers" xsi:type="array">
                <item name="default" xsi:type="object">Pronko\Core\Logger\Handler</item>
            </argument>
        </arguments>
    </virtualType>
</config>
